# =============================================================================
# CGI-242 Mobile — Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env
# =============================================================================

# URL de l'API backend (obligatoire)
# - Developpement : http://localhost:3003/api
# - Production    : https://api.cgi242.normx.ai/api
EXPO_PUBLIC_API_URL=http://localhost:3003/api

# Sentry DSN pour le monitoring d'erreurs (optionnel)
EXPO_PUBLIC_SENTRY_DSN=

# Cloudflare Turnstile (optionnel)
EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# Keycloak SSO (optionnel)
EXPO_PUBLIC_KEYCLOAK_URL=https://auth.example.com
EXPO_PUBLIC_KEYCLOAK_REALM=normx
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=normx-app
