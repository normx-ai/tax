    "expo-server-sdk": "^6.0.0",
    "expo-sharing": "^55.0.18",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "i18next": "^25.8.13",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
