{
  "name": "cgi-242-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "build:web": "EXPO_PUBLIC_API_URL=/api npx expo export --platform web",
    "deploy": "npm run build:web && rsync -avz --delete dist/ ubuntu@${DEPLOY_VPS_HOST}:/var/www/cgi242/"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
