// ==========================================
// CGI ENGINE - Schéma Prisma Multi-Tenant
// ==========================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ORGANIZATIONS (TENANTS) ====================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // URL-friendly identifier
  pays      String   @default("242") // Indicatif pays (242 = Congo-Brazzaville)
  logo      String?
  website   String?
  address   String?
  phone     String?

  // Paramètres
  settings Json? @default("{}")

  // Relations
  members       OrganizationMember[]
  invitations   Invitation[]
  subscription  Subscription?
  conversations Conversation[]
  usageStats    UsageStats[]
  seatRequests  SeatRequest[]
  invoices      Invoice[]

  // Soft delete
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
  @@map("organizations")
}

// ==================== USERS ====================

enum UserRole {
  USER
  ADMIN
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  role                 UserRole  @default(USER)
  firstName            String?
  lastName             String?
  phone                String?
  avatar               String?
  profession           String? // fiscaliste, expert-comptable, avocat, DAF, etc.

  isEmailVerified      Boolean   @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // MFA/2FA
  mfaEnabled           Boolean   @default(false)
  mfaSecret            String?   // Encrypted TOTP secret
  mfaBackupCodes       String[]  @default([]) // Hashed backup codes
  mfaVerifiedAt        DateTime?

  // Changement d'email en attente
  pendingEmail         String?

  // Verrouillage de compte (MISS-02)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?

  // Révocation globale des sessions (M2 — persistance blacklist)
  tokenRevokedAt       DateTime?

  // Abonnement personnel (si pas dans une orga)
  personalSubscription Subscription? @relation("PersonalSubscription")

  // Organisations
  memberships     OrganizationMember[]
  invitationsSent Invitation[]         @relation("InvitationSender")
  seatRequests    SeatRequest[]        @relation("SeatRequests")

  // Conversations personnelles (hors orga)
  personalConversations Conversation[] @relation("PersonalConversations")

  // Messages
  messages Message[]

  // Factures
  invoices Invoice[] @relation("UserInvoices")

  // Analytics personnelles
  searchHistory SearchHistory[]
  pushTokens    PushToken[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@map("users")
}

// ==================== ORGANIZATION MEMBERS ====================

enum OrganizationRole {
  OWNER  // Propriétaire - tous les droits
  ADMIN  // Admin - gestion membres, facturation
  MEMBER // Membre - utilisation standard
  VIEWER // Lecteur - lecture seule
}

model OrganizationMember {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  role OrganizationRole @default(MEMBER)

  // Permissions granulaires (optionnel, override du rôle)
  permissions Json? @default("{}")

  // Credits utilises ce mois par ce membre
  creditsUsed Int @default(0)

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ==================== INVITATIONS ====================

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model Invitation {
  id String @id @default(uuid())

  email String
  role  OrganizationRole @default(MEMBER)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("InvitationSender", fields: [invitedById], references: [id])

  token  String           @unique @default(uuid())
  status InvitationStatus @default(PENDING)

  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([email, organizationId])
  @@map("invitations")
}

// ==================== SUBSCRIPTIONS ====================

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  TRIALING
}

enum SubscriptionType {
  PERSONAL     // Abonnement individuel
  ORGANIZATION // Abonnement organisation
}

model Subscription {
  id String @id @default(uuid())

  type SubscriptionType

  // Lien vers User OU Organization (un seul des deux)
  userId String? @unique
  user   User?   @relation("PersonalSubscription", fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  // Credits
  creditsPerMonth  Int @default(0)  // Credits mensuels (reset chaque mois)
  creditsUsed      Int @default(0)  // Credits utilises ce mois
  creditsTotal     Int @default(10) // Credits totaux pour FREE (non-mensuel)
  creditsPurchased Int @default(0)  // Credits achetes via packs (ne se resetent pas)

  // Paiement
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Dates
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?

  // Historique paiements
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount          Decimal @db.Decimal(10, 2)
  currency        String  @default("XAF")
  status          String // succeeded, pending, failed
  paymentMethod   String?
  stripePaymentId String?
  metadata        Json?   // Données CinetPay ou Stripe

  // Facture associée
  invoice Invoice?

  createdAt DateTime @default(now())

  @@map("payments")
}

// ==================== INVOICES (FACTURES) ====================

model Invoice {
  id        String @id @default(uuid())

  // Type de facture
  type InvoiceType @default(AUTOMATIC)

  // Paiement associé (optionnel pour factures manuelles)
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // Liens vers User et/ou Organization
  userId String?
  user   User?   @relation("UserInvoices", fields: [userId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Numéro de facture séquentiel (FAC-YYYY-NNNNNN)
  invoiceNumber String @unique

  // Client
  customerName    String
  customerEmail   String
  customerAddress String?
  customerPhone   String?

  // Détails de la facture
  description String
  plan        String // Plan acheté

  // Montants
  amountHT  Decimal @db.Decimal(10, 2) // Hors Taxe
  tvaRate   Decimal @db.Decimal(5, 2)  @default(18.90) // Taux TVA Congo (18,9%)
  tvaAmount Decimal @db.Decimal(10, 2) // Montant TVA
  amountTTC Decimal @db.Decimal(10, 2) // Toutes Taxes Comprises

  currency String @default("XAF")

  // Fichier PDF
  pdfPath String? // Chemin vers le fichier PDF stocké
  pdfUrl  String? // URL publique du PDF

  // Statut
  status    InvoiceStatus @default(GENERATED)
  sentAt    DateTime?     // Date d'envoi par email
  paidAt    DateTime?     // Date de paiement (= date création pour paiement immédiat)

  // Période de facturation
  periodStart DateTime?
  periodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerEmail])
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT     // Brouillon
  GENERATED // Générée
  SENT      // Envoyée par email
  PAID      // Payée
  CANCELLED // Annulée
}

enum InvoiceType {
  AUTOMATIC // Générée automatiquement après paiement
  MANUAL    // Créée manuellement par l'admin
}

// ==================== CONVERSATIONS ====================

enum ConversationVisibility {
  PRIVATE    // Visible uniquement par le créateur
  TEAM       // Visible par toute l'organisation
  RESTRICTED // Visible par membres spécifiques
}

model Conversation {
  id String @id @default(uuid())

  title String?

  // Propriétaire
  creatorId String
  creator   User   @relation("PersonalConversations", fields: [creatorId], references: [id], onDelete: Cascade)

  // Organisation (null si conversation personnelle)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Visibilité (pour les conversations d'orga)
  visibility ConversationVisibility @default(PRIVATE)

  // Messages
  messages Message[]

  // Accès restreint (si visibility = RESTRICTED)
  sharedWith ConversationAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([organizationId])
  @@index([organizationId, updatedAt(sort: Desc)]) // Optimisation: liste conversations par org triées
  @@map("conversations")
}

model ConversationAccess {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String

  canEdit Boolean @default(false)

  grantedAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_access")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Auteur (pour les messages USER)
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  role    MessageRole
  content String      @db.Text

  // Métadonnées IA
  citations    Json?
  confidence   Float?
  tokensUsed   Int?
  responseTime Int? // en millisecondes

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt]) // Optimisation: messages triés par date
  @@map("messages")
}

// ==================== CGI ARTICLES ====================

enum ArticleStatut {
  EN_VIGUEUR
  ABROGE
  MODIFIE
  SANS_OBJET
}

model Article {
  id String @id @default(uuid())

  numero  String
  titre   String?
  chapeau String?  @db.Text
  contenu String   @db.Text

  // Localisation hiérarchique
  tome          String?
  partie        String?
  livre         String?
  chapitre      String?
  section       String?

  // Métadonnées
  version          String        @default("2025")
  statut           ArticleStatut @default(EN_VIGUEUR)
  dateEffet        DateTime?
  dateModification DateTime?
  source           String?
  pageDebut        Int?
  pageFin          Int?

  // Recherche
  keywords    String[] @default([])
  embeddingId String?  // ID dans Qdrant

  references    ArticleReference[] @relation("ArticleFrom")
  referencedBy  ArticleReference[] @relation("ArticleTo")
  searchHistory SearchHistory[]
  alertes       AlerteFiscale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contrainte unique sur numero + version + tome + livre (permet même numéro dans différents livres)
  @@unique([numero, version, tome, livre], name: "numero_version_tome_livre")
  @@index([numero])
  @@index([tome, livre, chapitre])
  @@index([statut])
  @@map("articles")
}

model ArticleReference {
  id            String  @id @default(uuid())
  fromArticleId String
  toArticleId   String
  fromArticle   Article @relation("ArticleFrom", fields: [fromArticleId], references: [id])
  toArticle     Article @relation("ArticleTo", fields: [toArticleId], references: [id])

  @@unique([fromArticleId, toArticleId])
  @@map("article_references")
}

// ==================== ANALYTICS ====================

model SearchHistory {
  id     String @id @default(uuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  query     String
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Index pour améliorer les performances des requêtes analytics
  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("search_history")
}

model UsageStats {
  id String @id @default(uuid())

  // Stats par user OU par orga
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  date           DateTime @db.Date
  questionsAsked Int      @default(0)
  articlesViewed Int      @default(0)
  tokensUsed     Int      @default(0)

  @@unique([userId, date])
  @@unique([organizationId, date])
  @@map("usage_stats")
}

// ==================== SYSTEM ====================

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ==================== ALERTES FISCALES ====================

enum AlerteType {
  ECHEANCE      // Délais/dates limites
  SEUIL         // Montants déclencheurs
  TAUX          // Taux applicables
  SANCTION      // Amendes/pénalités
  OBLIGATION    // Obligations déclaratives
}

enum AlerteCategorie {
  // Partie 1 - Livre 1 - Chapitre 1: IS
  IS                  // Impôt sur les sociétés
  PM_ETRANGERES       // Personnes morales étrangères
  MINIMUM_PERCEPTION  // Minimum de perception
  PRIX_TRANSFERT      // Prix de transfert

  // Partie 1 - Livre 1 - Chapitre 2: Impôts sur les revenus
  IBA                 // Impôt sur les bénéfices d'affaires
  IRCM                // Impôt sur le revenu des capitaux mobiliers
  IRF                 // Impôt sur les revenus fonciers
  ITS                 // Impôt sur les traitements et salaires

  // Partie 1 - Livre 1 - Chapitre 4: Dispositions communes
  DECLARATIONS        // Obligations déclaratives
  VERIFICATION        // Vérification et contrôle

  // Partie 1 - Livre 1 - Chapitre 5: Taxes diverses
  TAXE_TERRAINS       // Taxes sur les terrains
  TAXE_VEHICULES      // Taxe sur les véhicules de tourisme

  // Partie 2 - Impôts locaux
  FONCIER_BATI        // Contribution foncière propriétés bâties
  FONCIER_NON_BATI    // Contribution foncière propriétés non bâties
  PATENTE             // Contribution des patentes
  TAXE_REGIONALE      // Taxe régionale/départementale
  TAXE_SPECTACLES     // Taxe sur les spectacles
  TAXES_FACULTATIVES  // Taxes facultatives (ordures, véhicules)

  // Partie 3 - Dispositions communes
  SANCTIONS           // Sanctions fiscales
  RECOUVREMENT        // Recouvrement
  RECLAMATIONS        // Réclamations et contentieux

  // Tome 2 - TVA
  TVA                 // Taxe sur la valeur ajoutée
}

model AlerteFiscale {
  id            String   @id @default(uuid())

  // Contenu
  type          AlerteType
  categorie     AlerteCategorie
  titre         String
  description   String   @db.Text

  // Valeurs extraites
  valeur        String?           // "15" (jour), "100.000.000", "28%"
  valeurNumerique Decimal?        // Pour tri/comparaison
  unite         String?           // "jour", "FCFA", "%", "mois"
  periodicite   String?           // "mensuel", "trimestriel", "annuel"

  // Référence article source
  articleId     String?
  article       Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  articleNumero String            // "86A", "92B" - copie pour affichage

  // Métadonnées
  version       String   @default("2026")
  actif         Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([articleNumero, type, valeur, version])
  @@index([type])
  @@index([categorie])
  @@index([version])
  @@index([actif])
  @@map("alertes_fiscales")
}

// ==================== AUDIT TRAIL ====================

enum AuditAction {
  // Organization
  ORG_CREATED
  ORG_UPDATED
  ORG_DELETED
  ORG_RESTORED

  // Members
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
  OWNERSHIP_TRANSFERRED

  // Subscription
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  SEATS_REQUESTED
  SEATS_APPROVED
  SEATS_REJECTED

  // Data
  CONVERSATION_CREATED
  CONVERSATION_DELETED
  DATA_EXPORTED

  // User
  REGISTER
  USER_UPDATED
  SETTINGS_CHANGED

  // Security
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  LOGOUT_ALL
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  EMAIL_VERIFIED
  MFA_ENABLED
  MFA_DISABLED
  MFA_VERIFIED
  MFA_FAILED
  ACCOUNT_LOCKED

  // Permissions
  PERMISSION_GRANTED
  PERMISSION_REVOKED
  PERMISSIONS_RESET
  MEMBER_PERMISSIONS_UPDATED
}

model AuditLog {
  id String @id @default(uuid())

  // Qui a fait l'action ?
  actorId    String
  actorEmail String
  actorRole  String?

  // Quelle action ?
  action     AuditAction
  entityType String // Organization, User, Subscription, etc.
  entityId   String

  // Contexte organisation (optionnel)
  organizationId String?

  // Adresse IP de l'acteur (MISS-03)
  ipAddress String?

  // Détails des changements
  changes  Json // { before: {...}, after: {...} }
  metadata Json? // { ip, userAgent, reason, etc. }

  // Quand ?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ==================== AUDIT DOCUMENTS ====================

model DocumentAudit {
  id        String   @id @default(uuid())
  userId    String
  orgId     String?

  // Document analysé
  fileName  String
  fileType  String   // application/pdf, image/jpeg, etc.
  fileSize  Int      // en octets
  docType   String   // facture, contrat

  // Résultat
  score     Int      // mentions trouvées
  total     Int      // mentions attendues
  conforme  Boolean  // score == total
  result    Json     // AuditFactureResult complet

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([createdAt])
  @@map("document_audits")
}

// ==================== SEAT REQUESTS ====================

enum SeatRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model SeatRequest {
  id               String            @id @default(uuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedById    String
  requestedBy      User              @relation("SeatRequests", fields: [requestedById], references: [id])
  additionalSeats  Int
  currentSeats     Int               // snapshot au moment de la demande
  totalSeatsAfter  Int               // currentSeats + additionalSeats
  unitPrice        Int               // prix unitaire avec remise calculée
  totalPrice       Int               // additionalSeats × unitPrice
  plan             String            // plan au moment de la demande
  status           SeatRequestStatus @default(PENDING)
  adminNote        String?
  processedAt      DateTime?
  processedById    String?
  createdAt        DateTime          @default(now())

  @@index([organizationId])
  @@index([status])
  @@map("seat_requests")
}

// ==================== PUSH NOTIFICATIONS ====================

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("unknown")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_tokens")
}

// ==================== NEWSLETTER ====================
// Inscriptions newsletter via les landings (normx-ai, tax, app, legal).
// Double opt-in : confirm_token genere a l'inscription, valide quand
// l'utilisateur clique sur le lien dans l'email de confirmation. RGPD :
// unsubscribe_token + endpoint d'un clic.

enum NewsletterStatus {
  PENDING
  CONFIRMED
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id                String           @id @default(uuid())
  email             String           @unique
  status            NewsletterStatus @default(PENDING)
  confirmToken      String           @unique
  unsubscribeToken  String           @unique
  source            String?
  subscribedAt      DateTime         @default(now())
  confirmedAt       DateTime?
  unsubscribedAt    DateTime?

  @@index([status])
  @@map("newsletter_subscribers")
}
