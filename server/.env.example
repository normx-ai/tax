NODE_ENV=development
PORT=3004

# Base de donnees PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/cgi242?schema=public"

# JWT (OBLIGATOIRE — le serveur refuse de demarrer sans ces secrets)
# Generer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cle de chiffrement MFA (OBLIGATOIRE en production, fallback JWT_SECRET en dev)
# Generer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
MFA_ENCRYPTION_KEY=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3004

# CORS (plusieurs origines separees par des virgules)
CORS_ORIGIN=http://localhost:3004

# Qdrant (base vectorielle)
QDRANT_URL=http://localhost:6333

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# SMTP (envoi d'emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@cgi242.com

# Stripe (paiements)
# Tableau de bord : https://dashboard.stripe.com/test/apikeys
# Webhook signing secret : creer le endpoint POST /api/stripe/webhook puis copier le whsec_*
# Price IDs : creer Products PRO mensuel/annuel cote Stripe puis coller les price_*
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
# URL de retour post-Checkout (succes / annule)
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Secret partage avec l'app mobile native (HMAC)
# Generer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MOBILE_API_SECRET=

# Admin
ADMIN_EMAIL=contact@cgi242.com
